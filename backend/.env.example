OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
EMBEDDING_MODEL=all-MiniLM-L6-v2
NLI_MODEL=cross-encoder/nli-deberta-v3-small
